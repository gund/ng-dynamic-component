\n// With error message\nthrow new SemanticReleaseError(\"An error happened\");\n\n// With error message and error code\nthrow new SemanticReleaseError(\"An error happened\", \"ECODE\");\n\n// With error message, error code and details\nthrow new SemanticReleaseError(\"An error happened\", \"ECODE\", \"Here is some suggestions to solve this error.\");\n\n// With inheritance\nclass InheritedError extends SemanticReleaseError {\n  constructor(message, code, newProperty, details) {\n    super(message);\n    Error.captureStackTrace(this, this.constructor);\n    this.name = this.constructor.name;\n    this.code = code;\n    this.details = details;\n    this.newProperty = \"newProperty\";\n  }\n}\n\nthrow new InheritedError(\"An error happened\", \"ECODE\", \"Here is some suggestions to solve this error.\");\n```\n","engines":{"node":">=14.17"},"gitHead":"e94458017064d92157b261126982f0d98869e501","scripts":{"lint":"xo","test":"nyc ava -v","codecov":"codecov -f coverage/coverage-final.json","pretest":"npm run lint","test:ci":"nyc ava -v","semantic-release":"semantic-release"},"_npmUser":{"name":"semantic-release-bot","email":"semantic-release@martynus.net"},"prettier":{"printWidth":120,"trailingComma":"es5"},"renovate":{"extends":["github>semantic-release/.github"]},"repository":{"url":"git+https://github.com/semantic-release/error.git","type":"git"},"_npmVersion":"6.14.15","description":"errors with more than just a message","directories":{},"_nodeVersion":"14.17.6","publishConfig":{"access":"public"},"_hasShrinkwrap":false,"readmeFilename":"README.md","devDependencies":{"xo":"0.38.2","ava":"3.15.0","nyc":"15.1.0","codecov":"3.8.1"},"_npmOperationalInternal":{"tmp":"tmp/error_3.0.0-beta.1_1630688160173_0.3314140619048076","host":"s3://npm-registry-packages"}},"3.0.0":{"name":"@semantic-release/error","version":"3.0.0","keywords":["error","semantic-release"],"author":{"url":"http://boennemann.me","name":"Stephan Bönnemann","email":"stephan@boennemann.me"},"license":"MIT","